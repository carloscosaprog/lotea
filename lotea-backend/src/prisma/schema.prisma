generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario       Int      @id @default(autoincrement())
  nombre           String   @db.VarChar(100)
  email            String   @unique @db.VarChar(150)
  contrasena       String   @db.VarChar(255)
  avatar           String?
  fecha_registro   DateTime @default(now())

  lotes            Lote[]              @relation("VendedorLotes")
  favoritos        Favorito[]
  pedidos          Pedido[]
  grupos_creados   Grupo_Compra[]      @relation("CreadorGrupos")
  participaciones  Participacion_Grupo[]
  solicitudes      Solicitud_Lote[]
  mensajes_enviados   Mensaje[]        @relation("Emisor")
  mensajes_recibidos  Mensaje[]        @relation("Receptor")

  @@map("usuario")
}

model Categoria {
  id_categoria Int    @id @default(autoincrement())
  nombre       String @unique @db.VarChar(100)

  lotes        Lote[]

  @@map("categoria")
}

model Lote {
  id_lote          Int      @id @default(autoincrement())
  titulo           String   @db.VarChar(150)
  descripcion      String?
  precio           Decimal  @db.Decimal(10, 2)
  cantidad         Int
  id_vendedor      Int
  id_categoria     Int?
  fecha_publicacion DateTime @default(now())

  vendedor         Usuario    @relation("VendedorLotes", fields: [id_vendedor], references: [id_usuario], onDelete: Cascade)
  categoria        Categoria? @relation(fields: [id_categoria], references: [id_categoria], onDelete: SetNull)
  imagenes         Imagen_Lote[]
  favoritos        Favorito[]
  detalles_pedido  Detalle_Pedido[]
  grupos_compra    Grupo_Compra[]

  @@map("lote")
}

model Imagen_Lote {
  id_imagen    Int     @id @default(autoincrement())
  id_lote      Int
  url          String
  es_principal Boolean @default(false)

  lote         Lote    @relation(fields: [id_lote], references: [id_lote], onDelete: Cascade)

  @@map("imagen_lote")
}

model Favorito {
  id_favorito Int      @id @default(autoincrement())
  id_usuario  Int
  id_lote     Int
  fecha       DateTime @default(now())

  usuario     Usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  lote        Lote     @relation(fields: [id_lote], references: [id_lote], onDelete: Cascade)

  @@unique([id_usuario, id_lote])
  @@index([id_usuario])
  @@map("favorito")
}

model Pedido {
  id_pedido  Int      @id @default(autoincrement())
  id_usuario Int
  fecha      DateTime @default(now())
  estado     EstadoPedido @default(pendiente)

  usuario    Usuario          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  detalles   Detalle_Pedido[]

  @@map("pedido")
}

model Detalle_Pedido {
  id_detalle      Int     @id @default(autoincrement())
  id_pedido       Int
  id_lote         Int
  cantidad        Int
  precio_unitario Decimal @db.Decimal(10, 2)

  pedido          Pedido  @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)
  lote            Lote    @relation(fields: [id_lote], references: [id_lote], onDelete: Cascade)

  @@map("detalle_pedido")
}

model Grupo_Compra {
  id_grupo         Int      @id @default(autoincrement())
  id_lote          Int
  id_creador       Int
  cantidad_objetivo Int
  estado           EstadoGrupo @default(abierto)

  lote             Lote     @relation(fields: [id_lote], references: [id_lote], onDelete: Cascade)
  creador          Usuario  @relation("CreadorGrupos", fields: [id_creador], references: [id_usuario], onDelete: Cascade)
  participaciones  Participacion_Grupo[]

  @@map("grupo_compra")
}

model Participacion_Grupo {
  id_participacion  Int  @id @default(autoincrement())
  id_grupo          Int
  id_usuario        Int
  cantidad_aportada Int

  grupo             Grupo_Compra @relation(fields: [id_grupo], references: [id_grupo], onDelete: Cascade)
  usuario           Usuario      @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("participacion_grupo")
}

model Solicitud_Lote {
  id_solicitud Int      @id @default(autoincrement())
  id_usuario   Int
  descripcion  String
  fecha        DateTime @default(now())

  usuario      Usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("solicitud_lote")
}

model Mensaje {
  id_mensaje Int      @id @default(autoincrement())
  id_emisor  Int
  id_receptor Int
  contenido  String
  fecha      DateTime @default(now())

  emisor     Usuario  @relation("Emisor",   fields: [id_emisor],   references: [id_usuario], onDelete: Cascade)
  receptor   Usuario  @relation("Receptor", fields: [id_receptor], references: [id_usuario], onDelete: Cascade)

  @@map("mensaje")
}

enum EstadoPedido {
  pendiente
  completado
  cancelado
}

enum EstadoGrupo {
  abierto
  cerrado
}
